<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <label>New Recommendation Email Notification</label>
    <interviewLabel>New Recommendation Email {!$Flow.CurrentDateTime}</interviewLabel>
    <description>Sends email alert when a new Recommendation__c record is created</description>
    <processType>AutoLaunchedFlow</processType>
    <status>Active</status>

    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Send_Email</targetReference>
        </connector>
        <object>Recommendation__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>

    <actionCalls>
        <name>Send_Email</name>
        <label>Send Email</label>
        <locationX>50</locationX>
        <locationY>120</locationY>
        <actionName>emailSimple</actionName>
        <actionType>emailSimple</actionType>
        <inputParameters>
            <name>emailAddresses</name>
            <value><stringValue>chandrpratap2244706@agentforce.com</stringValue></value>
        </inputParameters>
        <inputParameters>
            <name>emailSubject</name>
            <value><elementReference>varSubject</elementReference></value>
        </inputParameters>
        <inputParameters>
            <name>emailBody</name>
            <value><elementReference>varBody</elementReference></value>
        </inputParameters>
    </actionCalls>

    <formulas>
        <name>varSubject</name>
        <dataType>String</dataType>
        <expression>"New AI Recommendation: " &amp; {!$Record.Product__r.Name} &amp; " for " &amp; {!$Record.Customer__r.Name} &amp; " - Rating: " &amp; TEXT({!$Record.Predicted_Rating__c}) &amp; "/5.0"</expression>
    </formulas>

    <formulas>
        <name>varBody</name>
        <dataType>String</dataType>
        <expression>"NEW AI RECOMMENDATION" &amp; "\n\nCustomer: " &amp; {!$Record.Customer__r.Name} &amp; "\nProduct: " &amp; {!$Record.Product__r.Name} &amp; "\nPredicted Rating: " &amp; TEXT({!$Record.Predicted_Rating__c}) &amp; "/5.0" &amp; "\nConfidence: " &amp; TEXT(ROUND({!$Record.Predicted_Rating__c} / 5 * 100, 0)) &amp; "%" &amp; "\n\nGenerated by SVD Collaborative Filtering" &amp; "\nFactors: 50 | RMSE: 0.84 | Epochs: 20" &amp; "\n\nRecoEngine - Salesforce AI System"</expression>
    </formulas>

</Flow>